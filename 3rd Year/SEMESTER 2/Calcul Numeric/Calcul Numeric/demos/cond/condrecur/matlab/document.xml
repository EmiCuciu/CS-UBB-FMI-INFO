<?xml version="1.0" encoding="UTF-8"?><w:document xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main"><w:body><w:p><w:pPr><w:pStyle w:val="title"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Condiționarea unei probleme. Recurențe directe și inverse</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="heading"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Problema 1</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Fie </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>E_n=\int\limits_{0}^{1}x^ne^{x-1}\,\mathrm{d}x</w:t></w:r></w:customXml><w:r><w:t>. Integrând prin părți se obține că</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>E_{1}=\frac{1}{e}</w:t></w:r></w:customXml><w:r><w:t> și </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>E_n=1-nE_{n-1},\  n=2,3,\dots</w:t></w:r></w:customXml></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Se poate arăta că </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>0&lt;E_n&lt;\frac{1}{n+1}</w:t></w:r></w:customXml><w:r><w:t> și că dacă </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>E_1=c</w:t></w:r></w:customXml><w:r><w:t> avem</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId1"/></w:customXmlPr><w:r><w:t>\lim_{n\to \infty } E_n =\left\lbrace \begin{array}{ll}
0, &amp; \textrm{pentru}\;c=\frac{1}{e}\\
\infty , &amp; \textrm{altfel}
\end{array}\right.</w:t></w:r></w:customXml></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Explicați fenomenul, propuneți un remediu și calculați </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>e=\exp(1)</w:t></w:r></w:customXml><w:r><w:t> cu precizia eps. </w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Aplicăm direct relația de recurență. Am implementat o funcție </w:t></w:r><w:r><w:rPr><w:rFonts w:cs="monospace"/></w:rPr><w:t>recdir</w:t></w:r><w:r><w:t>:</w:t></w:r></w:p><mc:AlternateContent xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"><mc:Choice Requires="R2018a"><w:sdt><w:sdtPr><w:alias w:val="codeexample_matlab"/></w:sdtPr><w:sdtContent><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[function E=recdir(n)]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[%recurenta directa]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[E=1/exp(1);]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[for k=2:n]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[    E=1-k*E;]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[end]]></w:t></w:r></w:p></w:sdtContent></w:sdt></mc:Choice><mc:Fallback><w:p><w:pPr><w:pStyle w:val="text"/></w:pPr><w:r><w:t></w:t></w:r></w:p></mc:Fallback></mc:AlternateContent><w:p><w:pPr><w:pStyle w:val="code"/></w:pPr><w:r><w:t><![CDATA[for n=2:25
    E=recdir(n);
    fprintf('E(%2d)=%+6.4e\n', n, E);
end]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Se obțin valori care nu sunt în concordanță. Vom calcula condiționarea problemei de calcul al integralei prin relația de recurență în punctul </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>E_1</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>E_n=1-nE_{n-1}=1-n\left(1-(n-1)E_{n-2} \right)
=1-n+n(n-1)E_{n-2}=\cdots=P(n)+(-1)^nn!E_1</w:t></w:r></w:customXml><w:r><w:t>,</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>unde </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>P(n)</w:t></w:r></w:customXml><w:r><w:t>este un polinom în </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>n</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Deci, avem </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>f(E_1)=P(n)+(-1)^{n}n!E_1</w:t></w:r></w:customXml><w:r><w:t>. Șirul </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>(E_n)</w:t></w:r></w:customXml><w:r><w:t> este descrescător. Obținem</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId2"/></w:customXmlPr><w:r><w:t>\textrm{cond}\left(f\right)\left(E_1 \right)=\frac{\left|E_1 \right|\left|\frac{\partial f}{\partial E_1 }\right|}{\left|E_n \right|}&gt;\frac{E_1 }{E_1 }n!\;=n!\;</w:t></w:r></w:customXml><w:r><w:t>,</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>adică eroarea relativă este amplificată cu </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>n!</w:t></w:r></w:customXml><w:r><w:t>. Chiar și pentru </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>n=18</w:t></w:r></w:customXml><w:r><w:t> se obține o eroare relativă &gt;1, deci o eroare mai mare decât rezultatul.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Să aplicăm recurența </w:t></w:r><w:r><w:rPr><w:b/><w:i/></w:rPr><w:t>în ordine inversă</w:t></w:r><w:r><w:t>: </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>E_{n-1}=\frac{1-E_n}{n}</w:t></w:r></w:customXml><w:r><w:t>. Vom porni de la valori mari spre valori mici: </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>n+k,n+k-1,\dots,n</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId3"/></w:customXmlPr><w:r><w:t>\begin{array}{l}
E_n =\frac{1-E_{n+1} }{n+1}=\frac{1-\frac{1-E_{n+2} }{n+2}}{n+1}=\frac{n+1+E_{n+2} }{\left(n+1\right)\left(n+2\right)}=\frac{1}{n+2}+\frac{E_{n+2} }{\left(n+1\right)\left(n+2\right)}\\
=\frac{n+2}{\left(n+3\right)\left(n+1\right)}-\frac{E_{n+3} }{\left(n+1\right)\left(n+2\right)\left(n+3\right)}\ldotp 
\end{array}</w:t></w:r></w:customXml></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Continuând în acest mod se obține</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId4"/></w:customXmlPr><w:r><w:t>E_n =Q\left(n\right)+{\left(-1\right)}^k \frac{E_{n+k} }{\left(n+1\right)\left(n+2\right)\cdots \left(n+k\right)},</w:t></w:r></w:customXml></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>unde </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>Q(n)</w:t></w:r></w:customXml><w:r><w:t> este o funcție rațională de </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>n</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Avem acum </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>E_n=g(E_{n+k})=Q(n)+(-1)^k\frac{E_{n+k}}{(n+1)(n+2)\cdots(n+k)}</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId5"/></w:customXmlPr><w:r><w:t>\begin{array}{l}
\textrm{cond}\left(g\right)\left(E_{n+k} \right)=\frac{\left|E_{n+k} \frac{\partial g\left(E_{n+k} \right)}{\partial E_{n+k} }\right|}{\left|E_n \right|}=\frac{E_{n+k} \frac{1}{\left(n+1\right)\left(n+2\right)\cdots \left(n+k\right)}}{E_n }\\
&lt;\frac{E_{n+k} \frac{1}{\left(n+1\right)\left(n+2\right)\cdots \left(n+k\right)}}{E_{n+k} }=\frac{1}{\left(n+1\right)\left(n+2\right)\cdots \left(n+k\right)},
\end{array}</w:t></w:r></w:customXml></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>adică, eroarea relativă va fi amplificată cu </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId6"/></w:customXmlPr><w:r><w:t>\frac{1}{\left(n+1\right)\left(n+2\right)\cdots \left(n+k\right)}</w:t></w:r></w:customXml><w:r><w:t>. Pentru </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>k</w:t></w:r></w:customXml><w:r><w:t> suficient de mare, acest factor va fi mic; deci vom putea alege orice valoare de pornire.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Funcția </w:t></w:r><w:r><w:rPr><w:rFonts w:cs="monospace"/></w:rPr><w:t>recinv</w:t></w:r><w:r><w:t> implementează recurența inversă:</w:t></w:r></w:p><mc:AlternateContent xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"><mc:Choice Requires="R2018a"><w:sdt><w:sdtPr><w:alias w:val="codeexample_matlab"/></w:sdtPr><w:sdtContent><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[function E=recinv(n,k)]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[%recurenta inversa]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[E=0;]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[for j=n+k:-1:n+1]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[    E=(1-E)/j;]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[end]]></w:t></w:r></w:p></w:sdtContent></w:sdt></mc:Choice><mc:Fallback><w:p><w:pPr><w:pStyle w:val="text"/></w:pPr><w:r><w:t></w:t></w:r></w:p></mc:Fallback></mc:AlternateContent><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Pornind de la o valoare </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>k</w:t></w:r></w:customXml><w:r><w:t> suficient de mare și luând </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>n=1</w:t></w:r></w:customXml><w:r><w:t>, putem calcula </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>\frac{1}{e}</w:t></w:r></w:customXml><w:r><w:t> cu precizia eps.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>După câteva experimente</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="code"/></w:pPr><w:r><w:t><![CDATA[for k=10:18
    E=recinv(1,k);
    err=abs(E-exp(-1))/exp(-1);
    fprintf('k=%2d, err=%e\n', k,err);
end]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>se observă că </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>k=17</w:t></w:r></w:customXml><w:r><w:t> este suficient.</w:t></w:r></w:p><w:p><w:pPr><w:sectPr/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="heading"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Problema 2</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Calculați </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId7"/></w:customXmlPr><w:r><w:t>\int_0^1 \frac{t^n }{t+5}\textrm{dt}</w:t></w:r></w:customXml><w:r><w:t>, pentru un întreg fixat </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>n\geq1</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Notăm </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>I_n=\int\limits_{0}^1 \frac{t^n}{t+5}dt</w:t></w:r></w:customXml><w:r><w:t>. Se observă că </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>I_0=\ln\frac{6}{5}</w:t></w:r></w:customXml><w:r><w:t> și </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>I_k=-5I_{k-1}+\frac{1}{k},\quad k=1,2,\dots,n</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Șirul </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>(I_n)</w:t></w:r></w:customXml><w:r><w:t> este descrescător și pozitiv. Dacă aplicăm direct relația de recurență</w:t></w:r></w:p><mc:AlternateContent xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"><mc:Choice Requires="R2018a"><w:sdt><w:sdtPr><w:alias w:val="codeexample_matlab"/></w:sdtPr><w:sdtContent><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[function Y=rec5dir(n)]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[Y=log(6/5);]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[for k=1:n]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[    Y=-5*Y+1/k;]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[end]]></w:t></w:r></w:p></w:sdtContent></w:sdt></mc:Choice><mc:Fallback><w:p><w:pPr><w:pStyle w:val="text"/></w:pPr><w:r><w:t></w:t></w:r></w:p></mc:Fallback></mc:AlternateContent><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>vom obține</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="code"/></w:pPr><w:r><w:t><![CDATA[for n=1:20
    y=recdir(n);
    fprintf('I(%2d)=%e\n',n,y);
end]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Ca la problema precedentă, vom calcula numărul de condiționare al problemei </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>I_n=f_n(I_0)</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Aplicând succesiv relația de recurență, avem</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId8"/></w:customXmlPr><w:r><w:t>\begin{array}{l}
I_n =-5I_{n-1} +\frac{1}{n}=-5\left(-5I_{n-2} +\frac{1}{n-1}\right)+\frac{1}{n}=5^2 I_{n-2} -\frac{5}{n-1}+\frac{1}{n}=\cdots \\
={\left(-5\right)}^n I_0 +P\left(n\right),
\end{array}</w:t></w:r></w:customXml></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>unde </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>P(n)</w:t></w:r></w:customXml><w:r><w:t> este o funcție rațională de </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>n</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>\mathrm{cond}(f)(I_0)=\frac{\left|I_0f'(I_0) \right|}{\left|I_n \right|}=\frac{I_05^n}{I_n}&gt;\frac{5^nI_0}{I_0}=5^n</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><w:p><w:pPr><w:sectPr/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Aplicând recurența în ordine inversă, </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>I_{k-1}=\frac{1}{5}\left(\frac{1}{k}-I_{k}\right),\ k=\nu,\nu-1,\dots,n+1</w:t></w:r></w:customXml><w:r><w:t>, obținem problema</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId9"/></w:customXmlPr><w:r><w:t>I_n =g_n \left(I_{\nu } \right),\nu &gt;n\ldotp</w:t></w:r></w:customXml></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId10"/></w:customXmlPr><w:r><w:t>\begin{array}{l}
I_n =\frac{1}{5}\left(\frac{1}{n+1}-I_{n+1} \right)=\frac{1}{5}\left(\frac{1}{n+1}-\frac{1}{5}\left(\frac{1}{n+2}-I_{n+2} \right)\right)=\cdots \\
=Q\left(n\right)+{\left(-\frac{1}{5}\right)}^{\nu -n} I_{\nu } 
\end{array}</w:t></w:r></w:customXml></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Din această relație, avem pentru condiționare</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId11"/></w:customXmlPr><w:r><w:t>\textrm{cond}\left(g_n \right)\left(I_{\nu } \right)=\frac{\left|I_{\nu } {g_n }^{\prime } \left(I_{\nu } \right)\right|}{\left|I_n \right|}=\frac{{\left(\frac{1}{5}\right)}^{\nu -n} I_{\nu } }{I_n }&lt;\frac{{\left(\frac{1}{5}\right)}^{\nu -n} I_{\nu } }{I_{\nu } }={\left(\frac{1}{5}\right)}^{\nu -n} \ldotp</w:t></w:r></w:customXml></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Din definiția condiționării vom avea</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId12"/></w:customXmlPr><w:r><w:t>\frac{\left|I_n^* -I_n \right|}{\left|I_n \right|}=\textrm{cond}\left(g_n \right)\left(I_{\nu } \right)\frac{\left|I_{\nu }^* -I_{\nu } \right|}{\left|I_{\nu } \right|}\le {\left(\frac{1}{5}\right)}^{\nu -n} \frac{\left|I_{\nu }^* -I_{\nu } \right|}{\left|I_{\nu } \right|}\ldotp</w:t></w:r></w:customXml><w:r><w:t> </w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Alegând valoarea de pornire </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>I_\nu^*=0</w:t></w:r></w:customXml><w:r><w:t>, o eroare la intrare de 100%, avem delimitarea</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId13"/></w:customXmlPr><w:r><w:t>\frac{\left|I_n^* -I_n \right|}{\left|I_n \right|}\le</w:t></w:r></w:customXml><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="true"/><w:attr w:name="encoding" w:val="mathml"/><w:attr w:name="relationshipId" w:val="rId14"/></w:customXmlPr><w:r><w:t>{\left(\frac{1}{5}\right)}^{\nu -n} \ldotp</w:t></w:r></w:customXml><w:r><w:t> </w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Pentru ca eroarea relativă să fie </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>\leq \varepsilon</w:t></w:r></w:customXml><w:r><w:t>, alegem </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>\nu</w:t></w:r></w:customXml><w:r><w:t> astfel ca </w:t></w:r><w:customXml w:element="equation"><w:customXmlPr><w:attr w:name="displayStyle" w:val="false"/></w:customXmlPr><w:r><w:t>\nu&gt;n+\frac{\ln \frac{1}{\varepsilon}}{\ln 5}</w:t></w:r></w:customXml><w:r><w:t>.</w:t></w:r></w:p><mc:AlternateContent xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"><mc:Choice Requires="R2018a"><w:sdt><w:sdtPr><w:alias w:val="codeexample_matlab"/></w:sdtPr><w:sdtContent><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[function Y=rec5inv(n,nu)]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[Y=0;]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[for k=nu:-1:n+1]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[    Y=1/5*(1/k-Y);]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CodeExampleLine"/></w:pPr><w:r><w:t><![CDATA[end]]></w:t></w:r></w:p></w:sdtContent></w:sdt></mc:Choice><mc:Fallback><w:p><w:pPr><w:pStyle w:val="text"/></w:pPr><w:r><w:t></w:t></w:r></w:p></mc:Fallback></mc:AlternateContent><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t>Exemplificăm cu</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="code"/></w:pPr><w:r><w:t><![CDATA[for k=10:-1:5
    Y=rec5inv(k,23+k);
    fi=@(t) t.^k./(t+5);
    Ym=integral(fi,0,1,'RelTol',eps);
    fprintf('%2d, %18.16f, %18.16f\n',k,Y,Ym)
end]]></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="text"/><w:jc w:val="left"/></w:pPr><w:r><w:t></w:t></w:r></w:p></w:body></w:document>